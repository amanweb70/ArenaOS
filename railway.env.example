# Railway supplies PORT automatically. Do not define it manually.
NODE_ENV=production
ARENA_STORAGE_DIRECTORY=/data/runs

# Model competition through OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=ArenaOS
OPENROUTER_SITE_URL=https://your-arenaos-domain.up.railway.app
OPENROUTER_TIMEOUT_MS=45000
OPENROUTER_MAX_OUTPUT_TOKENS=800
OPENROUTER_MAX_RETRIES=1
OPENROUTER_DATA_COLLECTION=deny

# Optional Codex environment workshop
OPENAI_API_KEY=
OPENAI_CODEX_MODEL=
