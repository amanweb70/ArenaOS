{
  "name": "arena-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "arena": "tsx apps/cli/src/index.ts",
    "dev": "pnpm run \"/^dev:.*/\"",
    "dev:api": "tsx apps/api/src/start.ts",
    "watch:api": "tsx watch apps/api/src/start.ts",
    "dev:web": "next dev apps/web --port 3000",
    "start:api": "tsx apps/api/src/start.ts",
    "build:web": "next build apps/web",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm build && pnpm test && pnpm build:web"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.7",
    "@fontsource/press-start-2p": "^5.2.7",
    "@react-three/drei": "^10.7.0",
    "@react-three/fiber": "^9.4.0",
    "@tanstack/react-query": "^5.90.0",
    "ajv": "^8.17.1",
    "chess.js": "^1.4.0",
    "fastify": "^5.6.0",
    "next": "^16.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@openai/codex": "^0.144.6",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/three": "^0.180.0",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "ws": "^8.18.3"
  }
}
