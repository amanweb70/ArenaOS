# One private key powers every configured live model. Never prefix it NEXT_PUBLIC_.
OPENROUTER_API_KEY=

# Server-side Codex environment builder. Never expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY=
OPENAI_CODEX_MODEL=gpt-5.6-sol
# Optional when the Codex binary is not available on PATH.
CODEX_BINARY=codex

# The six featured models and openrouter/auto are registered automatically.
# Add optional extra comma-separated model slugs here.
OPENROUTER_MODELS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=ArenaOS
OPENROUTER_SITE_URL=http://localhost:3000

# Per-call defaults. Runs also enforce their own aggregate token and dollar caps.
OPENROUTER_TIMEOUT_MS=45000
OPENROUTER_MAX_OUTPUT_TOKENS=800
OPENROUTER_MAX_RETRIES=1
OPENROUTER_TEMPERATURE=0
OPENROUTER_DATA_COLLECTION=deny
